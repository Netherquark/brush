export ANDROID_SDK_ROOT=
export ANDROID_HOME=
export ANDROID_NDK_HOME=
export CARGO_PATH=

# Optional Android build overrides
export ANDROID_ABI=arm64-v8a
export ANDROID_RUST_TARGET=aarch64-linux-android
export ANDROID_MIN_SDK=33
export ANDROID_NDK_VERSION=29.0.14206865

# Dynamically construct NDK-internal LLVM variables for bindgen
export LIBCLANG_PATH=
export CLANG_PATH=
export LD_LIBRARY_PATH=

# OpenCV linker paths/libs for the Android Rust build
export OPENCV_INCLUDE_PATHS=
export OPENCV_LINK_PATHS=
export OPENCV_LINK_LIBS=
